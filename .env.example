# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- LLM providers ----------------------------------------------------------

# Required for the OpenAI provider (Phase 1.3).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional. The Anthropic provider is stubbed until credits are acquired.
# Get one at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# --- Defaults ---------------------------------------------------------------

# Default LLM provider when --provider isn't passed to the CLI.
# Options: openai | anthropic
MCP_AGENT_PROVIDER=openai

# Default model per provider.
MCP_AGENT_OPENAI_MODEL=gpt-4o-mini
MCP_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-5
